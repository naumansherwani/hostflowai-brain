# HostFlow AI Brain — Environment Variables
# Copy this to .env and fill in real values on your Hetzner server
# DO NOT commit real values — this file shows keys only

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI (Replit proxy OR OpenAI compatible)
AI_INTEGRATIONS_OPENAI_BASE_URL=
AI_INTEGRATIONS_OPENAI_API_KEY=

# ElevenLabs
ELEVENLABS_API_KEY=

# Resend Email
RESEND_API_KEY=

# WhatsApp
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Payments (Polar.sh)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=

# Database
DATABASE_URL=

# Email Kill Switch (set to true to enable sending)
EMAIL_ENABLED=false

# Node
NODE_ENV=production
PORT=8080
